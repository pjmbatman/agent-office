{
  "name": "agent-office",
  "version": "1.0.0",
  "description": "2D Pokemon-style multi-agent orchestration desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "postinstall": "npm run rebuild:native",
    "rebuild:native": "electron-rebuild -f -o better-sqlite3",
    "typecheck:main": "tsc --noEmit -p src/main/tsconfig.json",
    "typecheck:preload": "tsc --noEmit -p src/preload/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p src/renderer/tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "test": "vitest run",
    "ready:check": "node scripts/service-readiness-check.mjs"
  },
  "dependencies": {
    "xstate": "^5.18.0",
    "zustand": "^5.0.0",
    "better-sqlite3": "^11.0.0",
    "ssh2": "^1.16.0",
    "easystarjs": "^0.4.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "phaser": "^3.80.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
